PORT=3001
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:4173
PUBLIC_CLIENT_URL=http://localhost:4173/
NODE_ENV=development
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=168
SOCKET_TICKET_TTL_SECONDS=30
SOCKET_TICKET_RATE_LIMIT=20
SOCKET_TICKET_RATE_WINDOW_SECONDS=60
OAUTH_STATE_TTL_SECONDS=600
OAUTH_START_RATE_LIMIT=10
OAUTH_START_RATE_WINDOW_SECONDS=900
DATABASE_URL=postgresql://tronos_app:CHANGE_ME@127.0.0.1:55432/tronos
MIGRATION_DATABASE_URL=postgresql://tronos_migrator:CHANGE_ME@127.0.0.1:55432/tronos
DATABASE_SSL=false
DATABASE_CERTIFICATE_BASE64=

# Crie o aplicativo no Discord Developer Portal e nunca envie estes valores ao Git.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Em produção, use o domínio público do frontend; a Netlify encaminha /api ao backend.
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback
