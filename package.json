{
  "name": "tronos-em-ruinas",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n CLIENT,SERVER -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace @tronos/client",
    "dev:server": "npm run dev --workspace @tronos/server",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "start": "npm run start --workspace @tronos/server",
    "db:start": "npm run db:start --workspace @tronos/server",
    "db:stop": "npm run db:stop --workspace @tronos/server",
    "db:provision": "npm run db:provision --workspace @tronos/server",
    "db:migrate": "npm run db:migrate --workspace @tronos/server",
    "db:verify": "npm run db:verify --workspace @tronos/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
